# TrackFinder — environment variable template
#
# Copy this file to `.env` for local development:   cp .env.example .env
# Then fill in real values. `.env` is git-ignored and must NEVER be committed.
#
# In production, set these same variables in:
#   Vercel → Settings → Environment Variables
# (not in this repo).

# --- SoundCloud (input: resolve playlist → tracklist) ---
# Register an app at https://developers.soundcloud.com (requires Artist Pro).
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=

# --- YouTube Data API v3 (search candidates + fetch durations) ---
# An API key is enough for read/search. Google Cloud Console → APIs & Services → Credentials.
YOUTUBE_API_KEY=

# --- Google OAuth (to create a playlist on the user's account) ---
# Google Cloud console: enable YouTube Data API v3, configure the OAuth consent
# screen, create an OAuth client ID (Web application), and register the redirect
# URIs http://localhost:3000/api/auth/youtube-callback and
# https://<your-vercel-domain>/api/auth/youtube-callback.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Anthropic (the ranking worker) ---
ANTHROPIC_API_KEY=

# --- Supabase (job state + search cache + OAuth token storage) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=   # server-side only — full access, never expose to the browser
SUPABASE_ANON_KEY=           # safe for client-side use
